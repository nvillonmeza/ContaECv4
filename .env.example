# ==========================================
# ContaEC - Ejemplo de Variables de Entorno
# Copie este archivo a .env y configure los valores
# cp .env.example .env
# ==========================================

# ==========================================
# Aplicación
# ==========================================
APP_NAME=ContaEC
APP_VERSION=4.0.0
APP_ENV=development
DEBUG=true

# ==========================================
# Claves Secretas (IMPORTANTE: Generar valores únicos para producción)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ==========================================
SECRET_KEY=
ENCRYPTION_KEY=
JWT_SECRET_KEY=

# ==========================================
# Base de Datos
# ==========================================
# Desarrollo: SQLite
DATABASE_URL=sqlite+aiosqlite:///./contaec.db

# Producción: PostgreSQL (descomentar y configurar)
# POSTGRES_USER=contaec_user
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=contaec_db

# ==========================================
# Usuario Administrador
# ==========================================
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ==========================================
# Clave de Cifrado para Respaldos
# ==========================================
BACKUP_ENCRYPTION_KEY=

# ==========================================
# Antivirus ClamAV
# ==========================================
CLAMAV_ENABLED=false
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ==========================================
# VirusTotal
# ==========================================
VIRUSTOTAL_ENABLED=false
VIRUSTOTAL_API_KEY=

# ==========================================
# CORS - Orígenes permitidos
# ==========================================
CORS_ORIGINS=http://localhost:3000

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# Servidor
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# Directorios
# ==========================================
TEMP_DIR=./temp
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
